
@model List<SV22T1020158.Models.Shop.CartItem>
@{
    ViewData["Title"] = "Thanh toán - Huy Shop";
    decimal total = Model.Sum(x => x.TotalPrice);
}

<div class="container py-4">
    <div class="mb-5 animate__animated animate__fadeIn">
        <h2 class="fw-extrabold text-dark mb-2">Xác nhận thanh toán</h2>
        <div style="width: 60px; height: 4px; background: linear-gradient(to right, #2563eb, #7c3aed); border-radius: 2px;"></div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8 animate__animated animate__fadeInLeft">
            <div class="card border-0 shadow-sm rounded-5 overflow-hidden mb-4">
                <div class="card-header bg-white border-0 py-4 px-4">
                    <h5 class="mb-0 fw-bold text-primary">
                        <i class="fa-solid fa-truck-fast me-2"></i>Thông tin giao hàng
                    </h5>
                </div>
                <div class="card-body px-4 pb-4">
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger border-0 rounded-4 shadow-sm mb-4">
                            <i class="fa-solid fa-circle-exclamation me-2"></i>@TempData["Error"]
                        </div>
                    }

                    <form method="post" asp-action="Checkout" id="checkoutForm">
                        <div class="row">
                            <div class="col-md-12 mb-4">
                                <label class="form-label fw-bold small text-muted">TỈNH / THÀNH PHỐ <span class="text-danger">*</span></label>
                                <select name="deliveryProvince" class="form-select form-select-lg rounded-4 border-light bg-light shadow-none focus-ring" required>
                                    <option value="">-- Chọn tỉnh/thành phố --</option>
                                    @foreach (var province in await SelectListHelper.Provinces())
                                    {
                                        <option value="@province.Value">@province.Text</option>
                                    }
                                </select>
                            </div>

                            <div class="col-md-12 mb-4">
                                <label class="form-label fw-bold small text-muted">ĐỊA CHỈ NHẬN HÀNG <span class="text-danger">*</span></label>
                                <textarea name="deliveryAddress" class="form-control rounded-4 border-light bg-light shadow-none focus-ring"
                                          rows="4" placeholder="Ví dụ: Số 123, đường Hùng Vương, phường Phú Nhuận..." required></textarea>
                            </div>
                        </div>

                        <div class="p-3 rounded-4 bg-primary bg-opacity-10 border border-primary border-opacity-10">
                            <div class="d-flex align-items-center text-primary">
                                <i class="fa-solid fa-circle-info fs-5 me-3"></i>
                                <span class="small fw-medium">Đơn hàng sẽ được nhân viên gọi xác nhận trong vòng 15-30 phút sau khi đặt.</span>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-4 animate__animated animate__fadeInRight">
            <div class="card border-0 shadow-lg rounded-5 overflow-hidden sticky-top" style="top: 20px; z-index: 10;">
                <div class="card-header border-0 py-4 px-4" style="background: linear-gradient(135deg, #1e3a8a 0%, #7c3aed 100%);">
                    <h5 class="mb-0 fw-bold text-white"><i class="fa-solid fa-receipt me-2"></i>Đơn hàng của bạn</h5>
                </div>
                <div class="card-body p-4 bg-white">
                    <div class="cart-items-preview mb-4" style="max-height: 300px; overflow-y: auto;">
                        @foreach (var item in Model)
                        {
                            <div class="d-flex align-items-center mb-3">
                                <div class="bg-light rounded-3 p-2 me-3 position-relative" style="width: 60px; height: 60px;">
                                    <i class="fa-solid fa-box text-muted position-absolute top-50 start-50 translate-middle"></i>
                                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-dark">
                                        @item.Quantity
                                    </span>
                                </div>
                               
                                <div class="text-end fw-bold small">
                                    @item.TotalPrice.ToString("#,##0") đ
                                </div>
                            </div>
                        }
                    </div>

                    <hr class="opacity-10">

                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Tạm tính:</span>
                        <span class="fw-bold">@total.ToString("#,##0") đ</span>
                    </div>
                    <div class="d-flex justify-content-between mb-4">
                        <span class="text-muted">Phí vận chuyển:</span>
                        <span class="text-success fw-bold">Miễn phí</span>
                    </div>

                    <div class="d-flex justify-content-between align-items-center p-3 bg-light rounded-4 mb-4">
                        <span class="fw-bold">Tổng thanh toán:</span>
                        <span class="text-primary fw-extrabold fs-4">@total.ToString("#,##0") đ</span>
                    </div>

                    <button type="submit" form="checkoutForm" class="btn btn-primary w-100 btn-lg rounded-pill py-3 fw-bold shadow-lg transition-all hover-up border-0"
                            style="background: linear-gradient(135deg, #2563eb 0%, #7c3aed 100%);">
                        XÁC NHẬN ĐẶT HÀNG <i class="fa-solid fa-circle-check ms-2"></i>
                    </button>

                    <a asp-controller="Cart" asp-action="Index" class="btn btn-link w-100 text-decoration-none mt-2 text-muted small fw-bold">
                        <i class="fa-solid fa-arrow-left me-2"></i>Quay lại giỏ hàng
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        background-color: #f8fafc;
    }

    .fw-extrabold {
        font-weight: 800;
    }

    .transition-all {
        transition: all 0.3s ease;
    }

    .hover-up:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 20px rgba(37, 99, 235, 0.2) !important;
    }

    .form-select-lg, .form-control {
        font-size: 0.95rem;
        padding: 0.8rem 1rem;
    }

    .focus-ring:focus {
        border-color: #7c3aed;
        box-shadow: 0 0 0 0.25rem rgba(124, 58, 237, 0.1);
        background-color: #fff;
    }

    .cart-items-preview::-webkit-scrollbar {
        width: 4px;
    }

    .cart-items-preview::-webkit-scrollbar-thumb {
        background: #e2e8f0;
        border-radius: 10px;
    }

    /* Animation đồng bộ với trang chủ */
    .animate__animated {
        --animate-duration: 0.8s;
    }
</style>