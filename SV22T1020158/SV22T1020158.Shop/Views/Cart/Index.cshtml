@model List<SV22T1020158.Models.Shop.CartItem>
@{
    ViewData["Title"] = "Giỏ hàng của tôi - Huy Shop";
    decimal total = Model.Sum(x => x.TotalPrice);
}

<div class="container py-5">
    <div class="d-flex align-items-center justify-content-between mb-5 animate__animated animate__fadeIn">
        <div>
            <h2 class="fw-extrabold text-dark mb-1">
                <i class="fa-solid fa-cart-shopping text-primary me-2"></i>Giỏ hàng của bạn
            </h2>
            <p class="text-muted mb-0">Bạn đang có <span class="text-primary fw-bold">@Model.Count</span> sản phẩm trong giỏ</p>
        </div>
        <a href="@Url.Action("Index", "Product")" class="btn btn-outline-primary rounded-pill px-4 fw-bold shadow-sm transition-all hover-up">
            <i class="fa-solid fa-arrow-left me-2"></i>Tiếp tục mua sắm
        </a>
    </div>

    @if (Model.Count == 0)
    {
        <div class="card border-0 shadow-sm rounded-5 py-5 animate__animated animate__zoomIn">
            <div class="card-body text-center py-5">
                <div class="mb-4">
                    <div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 120px; height: 120px;">
                        <i class="fa-solid fa-cart-plus fs-1 text-muted opacity-50"></i>
                    </div>
                </div>
                <h4 class="fw-bold">Giỏ hàng đang trống</h4>
                <p class="text-muted mb-4">Có vẻ như bạn chưa chọn được món đồ công nghệ nào ưng ý.</p>
                <a href="@Url.Action("Index", "Product")" class="btn btn-primary btn-lg rounded-pill px-5 fw-bold shadow-lg"
                   style="background: linear-gradient(135deg, #2563eb 0%, #7c3aed 100%); border: none;">
                    Mua sắm ngay thôi!
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">
            <div class="col-lg-8 animate__animated animate__fadeInLeft">
                <div class="card border-0 shadow-sm rounded-5 overflow-hidden">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light">
                                <tr class="text-muted small fw-bold">
                                    <th class="ps-4 py-3 border-0">SẢN PHẨM</th>
                                    <th class="text-center py-3 border-0">SỐ LƯỢNG</th>
                                    <th class="text-end py-3 border-0">GIÁ</th>
                                    <th class="text-end py-3 border-0">TỔNG</th>
                                    <th class="text-center py-3 border-0"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td class="ps-4 py-4">
                                            <div class="d-flex align-items-center">
                                                <div class="rounded-4 overflow-hidden shadow-sm me-3 border" style="width: 80px; height: 80px;">
                                                    <img src="~/images/products/@(string.IsNullOrEmpty(item.Photo) ? "nophoto.png" : item.Photo)"
                                                         class="w-100 h-100 object-fit-cover" alt="@item.ProductName">
                                                </div>
                                                <div>
                                                    <h6 class="fw-bold mb-1 text-dark">@item.ProductName</h6>
                                                    <span class="badge bg-light text-muted fw-normal">Đơn vị: @item.Unit</span>
                                                </div>
                                            </div>
                                        </td>
                                        <td style="width: 150px;">
                                            <form method="post" asp-action="UpdateCart" class="d-flex justify-content-center">
                                                <input type="hidden" name="productId" value="@item.ProductID" />
                                                <div class="input-group input-group-sm shadow-sm rounded-pill overflow-hidden border">
                                                    <input type="number" name="quantity" value="@item.Quantity" min="1"
                                                           class="form-control border-0 text-center fw-bold"
                                                           style="width: 60px; background: #fff;"
                                                           onchange="this.form.submit()" />
                                                </div>
                                            </form>
                                        </td>
                                        <td class="text-end fw-medium">@item.SalePrice.ToString("#,##0") đ</td>
                                        <td class="text-end fw-bold text-primary">@item.TotalPrice.ToString("#,##0") đ</td>
                                        <td class="text-center pe-4">
                                            <form method="post" asp-action="RemoveFromCart">
                                                <input type="hidden" name="productId" value="@item.ProductID" />
                                                <button type="submit" class="btn btn-link text-danger p-0 transition-all hover-scale"
                                                        onclick="return confirm('Xóa sản phẩm này?')">
                                                    <i class="fa-regular fa-trash-can fs-5"></i>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="mt-4 d-flex justify-content-between align-items-center px-2">
                    <form method="post" asp-action="ClearCart">
                        <button type="submit" class="btn btn-link text-muted text-decoration-none small fw-bold" onclick="return confirm('Làm trống giỏ hàng?')">
                            <i class="fa-solid fa-broom me-1"></i> Xóa tất cả giỏ hàng
                        </button>
                    </form>
                </div>
            </div>

            <div class="col-lg-4 animate__animated animate__fadeInRight">
                <div class="card border-0 shadow-lg rounded-5 overflow-hidden sticky-top" style="top: 20px;">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-4">Tóm tắt đơn hàng</h5>

                        <div class="d-flex justify-content-between mb-3 text-muted">
                            <span>Tạm tính</span>
                            <span>@total.ToString("#,##0") đ</span>
                        </div>
                        <div class="d-flex justify-content-between mb-3 text-muted">
                            <span>Giảm giá</span>
                            <span class="text-success fw-bold">- 0 đ</span>
                        </div>
                        <div class="d-flex justify-content-between mb-4 text-muted">
                            <span>Phí vận chuyển</span>
                            <span class="text-dark fw-bold small">Tính khi thanh toán</span>
                        </div>

                        <hr class="opacity-10 mb-4">

                        <div class="d-flex justify-content-between align-items-center mb-4 p-3 bg-light rounded-4">
                            <span class="fw-bold">Tổng cộng</span>
                            <span class="text-primary fw-extrabold fs-3">@total.ToString("#,##0") đ</span>
                        </div>

                        <a href="@Url.Action("Checkout")" class="btn btn-primary w-100 btn-lg rounded-pill py-3 fw-bold shadow-lg transition-all hover-up border-0"
                           style="background: linear-gradient(135deg, #2563eb 0%, #7c3aed 100%);">
                            TIẾN HÀNH THANH TOÁN <i class="fa-solid fa-chevron-right ms-2 small"></i>
                        </a>

                        <div class="mt-4 text-center">
                            <div class="d-flex justify-content-center gap-3 opacity-50">
                                <i class="fa-brands fa-cc-visa fs-3"></i>
                                <i class="fa-brands fa-cc-mastercard fs-3"></i>
                                <i class="fa-solid fa-building-columns fs-3"></i>
                                <i class="fa-solid fa-wallet fs-3"></i>
                            </div>
                            <p class="small text-muted mt-2 mb-0">Thanh toán an toàn & bảo mật</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<style>
    body {
        background-color: #f8fafc;
    }

    .fw-extrabold {
        font-weight: 800;
    }

    .transition-all {
        transition: all 0.3s ease;
    }

    .hover-up:hover {
        transform: translateY(-3px);
    }

    .hover-scale:hover {
        transform: scale(1.2);
        color: #dc3545 !important;
    }

    .table > :not(caption) > * > * {
        border-bottom-width: 1px;
        border-color: #f1f5f9;
    }

    input[type=number]::-webkit-inner-spin-button,
    input[type=number]::-webkit-outer-spin-button {
        opacity: 1; /* Hiện nút tăng giảm để dễ thao tác */
    }

    .sticky-top {
        z-index: 10;
    }
</style>