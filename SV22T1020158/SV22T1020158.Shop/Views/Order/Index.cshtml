
@model SV22T1020158.Models.Common.PagedResult<SV22T1020158.Models.Sales.OrderViewInfo>
@{
    ViewData["Title"] = "Đơn hàng của tôi - Huy Shop";
    int? currentStatus = ViewBag.CurrentStatus;
}

<div class="container py-4">
    <div class="row g-4">
        <div class="col-lg-3 animate__animated animate__fadeInLeft">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="list-group list-group-flush p-2">
                    <a href="@Url.Action("Profile", "ShopAccount")" class="list-group-item list-group-item-action border-0 rounded-3 mb-1 py-3">
                        <i class="fa-solid fa-user-circle me-2 text-primary"></i>Thông tin cá nhân
                    </a>
                    <a href="@Url.Action("ChangePassword", "ShopAccount")" class="list-group-item list-group-item-action border-0 rounded-3 mb-1 py-3">
                        <i class="fa-solid fa-shield-halved me-2 text-primary"></i>Đổi mật khẩu
                    </a>
                    <a href="@Url.Action("Index", "Order")" class="list-group-item list-group-item-action border-0 rounded-3 active py-3 shadow-sm">
                        <i class="fa-solid fa-box-open me-2"></i>Đơn hàng của tôi
                    </a>
                </div>
            </div>
        </div>

        <div class="col-lg-9 animate__animated animate__fadeIn">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-header bg-white border-0 p-4">
                    <h5 class="fw-extrabold text-dark mb-0">
                        <i class="fa-solid fa-clock-history text-primary me-2"></i>Lịch sử đơn hàng
                    </h5>
                </div>

                <div class="px-4 pb-2 border-bottom overflow-auto">
                    <div class="d-flex gap-2 pb-2" style="min-width: 600px;">
                        <a href="@Url.Action("Index", new { status = (int?)null })"
                           class="status-tab @(currentStatus == null ? "active" : "")">Tất cả</a>

                        <a href="@Url.Action("Index", new { status = 1 })"
                           class="status-tab @(currentStatus == 1 ? "active" : "")">Chờ duyệt</a>

                        <a href="@Url.Action("Index", new { status = 2 })"
                           class="status-tab @(currentStatus == 2 ? "active" : "")">Đã duyệt</a>

                        <a href="@Url.Action("Index", new { status = 3 })"
                           class="status-tab @(currentStatus == 3 ? "active" : "")">Đang giao</a>

                        <a href="@Url.Action("Index", new { status = 4 })"
                           class="status-tab @(currentStatus == 4 ? "active" : "")">Hoàn tất</a>

                        <a href="@Url.Action("Index", new { status = -1 })"
                           class="status-tab @(currentStatus == -1 ? "active" : "")">Đã hủy</a>
                    </div>
                </div>

                <div class="card-body p-4">
                    @if (Model.DataItems.Count == 0)
                    {
                        <div class="text-center py-5">
                            <img src="~/images/empty-order.png" class="mb-3 opacity-50" style="width: 120px;" onerror="this.src='https://cdn-icons-png.flaticon.com/512/4076/4076432.png'">
                            <p class="text-muted fw-medium">Bạn chưa có đơn hàng nào trong mục này.</p>
                            <a href="@Url.Action("Index", "Product")" class="btn btn-primary rounded-pill px-4">Mua sắm ngay</a>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle border-0">
                                <thead class="text-muted small">
                                    <tr>
                                        <th class="border-0 ps-0">MÃ ĐƠN</th>
                                        <th class="border-0">NGÀY ĐẶT</th>
                                        <th class="border-0 text-end">TỔNG TIỀN</th>
                                        <th class="border-0 text-center">TRẠNG THÁI</th>
                                        <th class="border-0"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var order in Model.DataItems)
                                    {
                                        <tr>
                                            <td class="ps-0 py-3">
                                                <span class="fw-bold text-dark">#@order.OrderID</span>
                                            </td>
                                            <td>
                                                <div class="small text-dark">@order.OrderTime.ToString("dd/MM/yyyy")</div>
                                                <div class="text-muted small" style="font-size: 11px;">@order.OrderTime.ToString("HH:mm")</div>
                                            </td>
                                            <td class="text-end fw-extrabold text-primary">
                                                @order.TotalPrice.ToString("#,##0") đ
                                            </td>
                                            <td class="text-center">
                                                @switch (order.Status)
                                                {
                                                    case OrderStatusEnum.New:
                                                        <span class="badge rounded-pill bg-warning text-dark px-3 py-2">Chờ duyệt</span>
                                                        break;
                                                    case OrderStatusEnum.Accepted:
                                                        <span class="badge rounded-pill bg-primary px-3 py-2">Đã duyệt</span>
                                                        break;
                                                    case OrderStatusEnum.Shipping:
                                                        <span class="badge rounded-pill bg-info px-3 py-2">Đang giao</span>
                                                        break;
                                                    case OrderStatusEnum.Completed:
                                                        <span class="badge rounded-pill bg-success px-3 py-2">Hoàn tất</span>
                                                        break;
                                                    case OrderStatusEnum.Cancelled:
                                                        <span class="badge rounded-pill bg-secondary px-3 py-2">Đã hủy</span>
                                                        break;
                                                    case OrderStatusEnum.Rejected:
                                                        <span class="badge rounded-pill bg-danger px-3 py-2">Bị từ chối</span>
                                                        break;
                                                }
                                            </td>
                                            <td class="text-end pe-0">
                                                <a href="@Url.Action("Detail", new { id = order.OrderID })"
                                                   class="btn btn-light btn-sm rounded-pill px-3 fw-bold border transition-all hover-up">
                                                    Chi tiết
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        @if (Model.PageCount > 1)
                        {
                            <nav class="mt-4">
                                <ul class="pagination justify-content-center gap-1">
                                    @for (int i = 1; i <= Model.PageCount; i++)
                                    {
                                        <li class="page-item @(i == Model.Page ? "active" : "")">
                                            <a class="page-link border-0 rounded-circle shadow-sm mx-1 text-center"
                                               style="width: 40px; height: 40px; line-height: 24px;"
                                               href="@Url.Action("Index", new { page = i, status = currentStatus })">@i</a>
                                        </li>
                                    }
                                </ul>
                            </nav>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .fw-extrabold {
        font-weight: 800;
    }

    .transition-all {
        transition: all 0.3s ease;
    }

    .hover-up:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 8px rgba(0,0,0,0.05);
    }

    /* Custom Status Tabs */
    .status-tab {
        padding: 8px 20px;
        border-radius: 50px;
        text-decoration: none;
        color: #64748b;
        font-size: 14px;
        font-weight: 600;
        white-space: nowrap;
        transition: all 0.2s;
        border: 1px solid transparent;
    }

        .status-tab:hover {
            background-color: #f1f5f9;
            color: #2563eb;
        }

        .status-tab.active {
            background-color: #eff6ff;
            color: #2563eb;
            border-color: #bfdbfe;
        }

    /* Pagination Styling */
    .page-link {
        color: #64748b;
    }

    .page-item.active .page-link {
        background: linear-gradient(135deg, #2563eb 0%, #7c3aed 100%);
        color: white;
    }

    .list-group-item.active {
        background: linear-gradient(135deg, #2563eb 0%, #7c3aed 100%) !important;
        border: none !important;
    }
</style>