@model SV22T1020158.Shop.Models.ChangePasswordViewModel
@{
    ViewData["Title"] = "Đổi mật khẩu";
    Layout = "_Layout";
}

<style>
    /* Sidebar Styling */
    .profile-sidebar {
        background: white;
        border-radius: 25px;
        border: 1px solid rgba(226, 232, 240, 0.8);
        box-shadow: 0 10px 25px rgba(30, 58, 138, 0.05);
        overflow: hidden;
    }

    .list-group-item-tech {
        border: none;
        padding: 15px 20px;
        font-weight: 700;
        color: #64748b;
        transition: all 0.3s;
        font-size: 0.9rem;
    }

        .list-group-item-tech:hover {
            background: #f1f5f9;
            color: #1e3a8a;
        }

        .list-group-item-tech.active {
            background: linear-gradient(135deg, #1e3a8a 0%, #7c3aed 100%);
            color: white;
        }

    /* Card Styling */
    .tech-card {
        background: white;
        border-radius: 30px;
        border: none;
        box-shadow: 0 20px 40px rgba(30, 58, 138, 0.1);
        padding: 20px;
    }

    .tech-card-header {
        background: linear-gradient(135deg, #1e3a8a 0%, #7c3aed 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        font-weight: 900;
        font-size: 1.5rem;
        margin-bottom: 25px;
        display: flex;
        align-items: center;
    }

    /* Form Elements */
    .form-label-tech {
        font-weight: 800;
        color: #475569;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 8px;
        display: block;
    }

    .input-group-tech {
        background: #f1f5f9;
        border-radius: 15px;
        padding: 5px 15px;
        transition: all 0.3s;
        border: 2px solid transparent;
        display: flex;
        align-items: center;
        margin-bottom: 5px;
    }

        .input-group-tech:focus-within {
            background: white;
            border-color: #7c3aed;
            box-shadow: 0 8px 15px rgba(124, 58, 237, 0.1);
        }

        .input-group-tech i {
            color: #94a3b8;
            font-size: 1.1rem;
        }

        .input-group-tech input {
            border: none;
            background: transparent;
            padding: 10px;
            width: 100%;
            outline: none;
            font-weight: 600;
            color: #1e293b;
        }

    /* Buttons */
    .btn-save-tech {
        background: linear-gradient(135deg, #1e3a8a 0%, #7c3aed 100%);
        color: white;
        border: none;
        border-radius: 15px;
        font-weight: 700;
        padding: 12px 25px;
        transition: all 0.3s;
        box-shadow: 0 10px 20px rgba(124, 58, 237, 0.2);
    }

        .btn-save-tech:hover {
            transform: translateY(-2px);
            box-shadow: 0 15px 25px rgba(124, 58, 237, 0.3);
            filter: brightness(1.1);
            color: white;
        }

    .btn-back-tech {
        background: #f1f5f9;
        color: #64748b;
        border: none;
        border-radius: 15px;
        font-weight: 700;
        padding: 12px 25px;
        transition: all 0.3s;
    }

        .btn-back-tech:hover {
            background: #e2e8f0;
            color: #1e293b;
        }
</style>

<div class="container py-5">
    <div class="row g-4">
        <div class="col-md-4 col-lg-3">
            <div class="profile-sidebar">
                <div class="p-4 text-center bg-light mb-2">
                    <div class="bg-white d-inline-block p-3 rounded-circle shadow-sm mb-2">
                        <i class="bi bi-shield-lock-fill text-primary fs-3"></i>
                    </div>
                    <h6 class="fw-bold text-dark mb-0">Bảo mật tài khoản</h6>
                </div>
                <div class="list-group list-group-flush">
                    <a href="@Url.Action("Profile")" class="list-group-item list-group-item-action list-group-item-tech">
                        <i class="bi bi-person me-2"></i> Thông tin cá nhân
                    </a>
                    <a href="@Url.Action("ChangePassword")" class="list-group-item list-group-item-action list-group-item-tech active">
                        <i class="bi bi-key me-2"></i> Đổi mật khẩu
                    </a>
                    <a href="@Url.Action("Index", "Order")" class="list-group-item list-group-item-action list-group-item-tech">
                        <i class="bi bi-receipt me-2"></i> Đơn hàng của tôi
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-8 col-lg-9">
            <div class="tech-card">
                <h2 class="tech-card-header">
                    <i class="bi bi-shield-check me-2" style="-webkit-text-fill-color: #1e3a8a"></i>
                    Cập nhật mật khẩu
                </h2>

                <form method="post" asp-action="ChangePassword">
                    <div class="row">
                        <div class="col-lg-8">
                            <div class="mb-4">
                                <label asp-for="OldPassword" class="form-label-tech">Mật khẩu hiện tại</label>
                                <div class="input-group-tech">
                                    <i class="bi bi-lock"></i>
                                    <input asp-for="OldPassword" type="password" placeholder="Nhập mật khẩu cũ" />
                                </div>
                                <span asp-validation-for="OldPassword" class="text-danger small fw-bold"></span>
                            </div>

                            <div class="mb-4">
                                <label asp-for="NewPassword" class="form-label-tech">Mật khẩu mới</label>
                                <div class="input-group-tech">
                                    <i class="bi bi-key-fill"></i>
                                    <input asp-for="NewPassword" type="password" placeholder="Tối thiểu 6 ký tự" />
                                </div>
                                <span asp-validation-for="NewPassword" class="text-danger small fw-bold"></span>
                            </div>

                            <div class="mb-4">
                                <label asp-for="ConfirmPassword" class="form-label-tech">Xác nhận mật khẩu mới</label>
                                <div class="input-group-tech">
                                    <i class="bi bi-check-circle"></i>
                                    <input asp-for="ConfirmPassword" type="password" placeholder="Nhập lại mật khẩu mới" />
                                </div>
                                <span asp-validation-for="ConfirmPassword" class="text-danger small fw-bold"></span>
                            </div>

                            <div class="mt-5 d-flex gap-3">
                                <button type="submit" class="btn btn-save-tech">
                                    <i class="bi bi-arrow-repeat me-2"></i> CẬP NHẬT NGAY
                                </button>
                                <a href="@Url.Action("Profile")" class="btn btn-back-tech">
                                    QUAY LẠI
                                </a>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>