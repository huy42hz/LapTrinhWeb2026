@{
    ViewData["Title"] = "Đăng nhập";
    Layout = "_LayoutEmpty";
}

<style>
    
    body {
        background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
        min-height: 100vh;
        display: flex;
        align-items: center;
    }

    .login-container {
        max-width: 450px;
        width: 100%;
        margin: auto;
    }

    .login-card {
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(10px);
        border-radius: 30px;
        border: 1px solid rgba(255, 255, 255, 0.2);
        box-shadow: 0 25px 50px -12px rgba(30, 58, 138, 0.15);
        padding: 40px;
    }

    .shop-logo-tech {
        font-size: 2.5rem;
        font-weight: 900;
        letter-spacing: -1.5px;
        display: block;
        margin-bottom: 30px;
    }

    .logo-blue {
        color: #1e3a8a;
    }

    .logo-purple {
        background: linear-gradient(135deg, #1e3a8a 0%, #7c3aed 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    /* Form Styling */
    .form-label {
        font-weight: 700;
        color: #475569;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-left: 5px;
    }

    .input-group-tech {
        background: #f1f5f9;
        border-radius: 15px;
        padding: 5px 15px;
        transition: all 0.3s;
        border: 2px solid transparent;
        display: flex;
        align-items: center;
        margin-bottom: 20px;
    }

        .input-group-tech:focus-within {
            background: white;
            border-color: #7c3aed;
            box-shadow: 0 10px 20px rgba(124, 58, 237, 0.1);
        }

        .input-group-tech i {
            color: #94a3b8;
            font-size: 1.2rem;
        }

        .input-group-tech input {
            border: none;
            background: transparent;
            padding: 12px;
            width: 100%;
            outline: none;
            font-weight: 600;
            color: #1e293b;
        }

    .btn-login-tech {
        background: linear-gradient(135deg, #1e3a8a 0%, #7c3aed 100%);
        color: white;
        border: none;
        border-radius: 15px;
        font-weight: 700;
        padding: 15px;
        width: 100%;
        margin-top: 10px;
        transition: all 0.3s;
        box-shadow: 0 10px 20px rgba(124, 58, 237, 0.2);
    }

        .btn-login-tech:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 30px rgba(124, 58, 237, 0.3);
            filter: brightness(1.1);
            color: white;
        }

    .divider {
        height: 1px;
        background: #e2e8f0;
        margin: 30px 0;
        position: relative;
    }

        .divider::after {
            content: "HOẶC";
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            background: white;
            padding: 0 15px;
            color: #94a3b8;
            font-size: 0.75rem;
            font-weight: 800;
        }

    .btn-register-link {
        color: #7c3aed;
        text-decoration: none;
        font-weight: 700;
        transition: all 0.2s;
    }

        .btn-register-link:hover {
            color: #1e3a8a;
        }
</style>

<div class="login-container">
    <div class="login-card">
        <div class="text-center">
            <a href="/" class="shop-logo-tech text-decoration-none">
                <span class="logo-blue">Huy</span><span class="logo-purple">Shop</span>
            </a>
            <h4 class="fw-bold text-dark mb-4">Chào mừng trở lại!</h4>
        </div>

        @if (!string.IsNullOrEmpty(ViewBag.Error))
        {
            <div class="alert alert-danger border-0 rounded-4 shadow-sm mb-4 py-3">
                <i class="bi bi-exclamation-circle-fill me-2"></i> @ViewBag.Error
            </div>
        }

        <form method="post" asp-action="Login">
            <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />

            <div class="form-group">
                <label class="form-label">Email tài khoản</label>
                <div class="input-group-tech">
                    <i class="bi bi-envelope-at"></i>
                    <input type="email" name="email" value="@ViewBag.Email" placeholder="name@company.com" autofocus required />
                </div>
            </div>

            <div class="form-group">
                <div class="d-flex justify-content-between align-items-center">
                    <label class="form-label">Mật khẩu</label>
                    <a href="#" class="small text-muted text-decoration-none mb-2">Quên mật khẩu?</a>
                </div>
                <div class="input-group-tech">
                    <i class="bi bi-shield-lock"></i>
                    <input type="password" name="password" placeholder="••••••••" required />
                </div>
            </div>

            <button type="submit" class="btn btn-login-tech">
                <i class="bi bi-box-arrow-in-right me-2"></i> ĐĂNG NHẬP NGAY
            </button>
        </form>

        <div class="divider"></div>

        <div class="text-center">
            <p class="text-secondary mb-0">Bạn chưa có tài khoản?</p>
            <a asp-action="Register" class="btn-register-link">Tạo tài khoản mới tại đây</a>
        </div>
    </div>

    <div class="text-center mt-4">
        <a href="/" class="text-muted text-decoration-none small">
            <i class="bi bi-arrow-left me-1"></i> Quay lại trang chủ
        </a>
    </div>
</div>