
@model SV22T1020158.Shop.Models.RegisterViewModel
@{
    ViewData["Title"] = "Đăng ký tài khoản";
    Layout = "_Layout"; 
}

<style>
    .register-card {
        border: none;
        border-radius: 30px;
        background: white;
        box-shadow: 0 20px 60px rgba(30, 58, 138, 0.1);
        overflow: hidden;
    }

    .register-header {
        background: linear-gradient(135deg, #1e3a8a 0%, #7c3aed 100%);
        color: white;
        padding: 30px;
        text-align: center;
        border: none;
    }   

    .form-section-title {
        font-size: 0.8rem;
        font-weight: 800;
        color: #94a3b8;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
    }

        .form-section-title::after {
            content: "";
            flex: 1;
            height: 1px;
            background: #e2e8f0;
            margin-left: 15px;
        }

    /* Input Styling */
    .form-label {
        font-weight: 700;
        color: #475569;
        font-size: 0.85rem;
        margin-bottom: 8px;
    }

    .form-control, .form-select {
        border-radius: 12px;
        padding: 12px 15px;
        border: 1px solid #e2e8f0;
        background-color: #f8fafc;
        transition: all 0.3s;
    }

        .form-control:focus, .form-select:focus {
            background-color: #fff;
            border-color: #7c3aed;
            box-shadow: 0 0 0 4px rgba(124, 58, 237, 0.1);
        }

    .btn-register-tech {
        background: linear-gradient(135deg, #1e3a8a 0%, #7c3aed 100%);
        color: white;
        border: none;
        border-radius: 15px;
        font-weight: 700;
        padding: 15px;
        transition: all 0.3s;
        box-shadow: 0 10px 20px rgba(124, 58, 237, 0.2);
    }

        .btn-register-tech:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 30px rgba(124, 58, 237, 0.3);
            filter: brightness(1.1);
            color: white;
        }

    .form-text {
        font-size: 0.75rem;
        color: #94a3b8;
    }
</style>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">
            <div class="card register-card">
                <div class="register-header">
                    <h3 class="fw-black mb-1">GIA NHẬP HUYSHOP</h3>
                    <p class="mb-0 opacity-75">Tạo tài khoản để trải nghiệm mua sắm công nghệ tốt nhất</p>
                </div>

                <div class="card-body p-4 p-lg-5">
                    <form method="post" asp-action="Register">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 rounded-4 small"></div>

                        <div class="form-section-title">Thông tin tài khoản</div>
                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <label asp-for="Email" class="form-label">Email đăng nhập <span class="text-danger">*</span></label>
                                <input asp-for="Email" class="form-control" placeholder="example@email.com" />
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="CustomerName" class="form-label">Họ và tên <span class="text-danger">*</span></label>
                                <input asp-for="CustomerName" class="form-control" placeholder="Nhập tên đầy đủ" />
                                <span asp-validation-for="CustomerName" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Password" class="form-label">Mật khẩu <span class="text-danger">*</span></label>
                                <input asp-for="Password" class="form-control" type="password" placeholder="••••••••" />
                                <div class="form-text">Tối thiểu 6 ký tự.</div>
                                <span asp-validation-for="Password" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="ConfirmPassword" class="form-label">Xác nhận mật khẩu <span class="text-danger">*</span></label>
                                <input asp-for="ConfirmPassword" class="form-control" type="password" placeholder="••••••••" />
                                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="form-section-title">Thông tin liên hệ & Giao hàng</div>
                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <label asp-for="Phone" class="form-label">Số điện thoại</label>
                                <input asp-for="Phone" class="form-control" placeholder="0xxx..." />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="ContactName" class="form-label">Tên giao dịch (Nếu có)</label>
                                <input asp-for="ContactName" class="form-control" placeholder="Tên thường dùng" />
                            </div>
                            <div class="col-12">
                                <label asp-for="Province" class="form-label">Tỉnh / Thành phố</label>
                                <select asp-for="Province" class="form-select" asp-items="await SelectListHelper.Provinces()">
                                    <option value="">-- Chọn tỉnh/thành phố --</option>
                                </select>
                            </div>
                            <div class="col-12">
                                <label asp-for="Address" class="form-label">Địa chỉ chi tiết</label>
                                <textarea asp-for="Address" class="form-control" rows="2" placeholder="Số nhà, tên đường..."></textarea>
                            </div>
                        </div>

                        <div class="pt-2">
                            <button type="submit" class="btn btn-register-tech w-100 mb-3">
                                <i class="bi bi-person-check-fill me-2"></i> HOÀN TẤT ĐĂNG KÝ
                            </button>
                        </div>
                    </form>

                    <div class="text-center mt-4 pt-3 border-top">
                        <p class="text-muted mb-0">
                            Bạn đã có tài khoản?
                            <a asp-action="Login" class="fw-bold text-decoration-none" style="color: #7c3aed;">Đăng nhập ngay</a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}