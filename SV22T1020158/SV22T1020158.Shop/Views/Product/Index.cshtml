@model SV22T1020158.Shop.Models.ProductSearchViewModel
@{
    ViewData["Title"] = "Sản phẩm";
}

<style>
    /* Đồng bộ với phong cách Blue - Purple Tech của Home */
    :root {
        --primary-gradient: linear-gradient(135deg, #1e3a8a 0%, #7c3aed 100%);
        --accent-color: #2563eb;
        --soft-bg: #f8fafc;
    }

    .modern-card {
        border-radius: 24px;
        border: none;
        box-shadow: 0 10px 30px rgba(30, 58, 138, 0.08);
        overflow: hidden;
        background: #fff;
    }

    .tech-header {
        background: var(--primary-gradient);
        color: white;
        padding: 20px 25px;
        border-bottom: none;
    }

    .form-control, .form-select {
        border-radius: 12px;
        border: 1px solid #e2e8f0;
        padding: 10px 15px;
        transition: all 0.3s;
    }

        .form-control:focus, .form-select:focus {
            border-color: #7c3aed;
            box-shadow: 0 0 0 4px rgba(124, 58, 237, 0.15);
        }

    .btn-search-tech {
        background: var(--primary-gradient);
        color: white;
        border-radius: 12px;
        font-weight: 700;
        transition: all 0.3s;
        border: none;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }

        .btn-search-tech:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(37, 99, 235, 0.3);
            color: white;
            filter: brightness(1.1);
        }

    /* Đảm bảo khung kết quả đồng bộ với Card sản phẩm ở Home */
    #searchResult {
        min-height: 300px;
    }

    /* Style cho nhãn input */
    .filter-label {
        font-size: 0.75rem;
        font-weight: 800;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 8px;
        display: block;
    }

    /* Hiệu ứng loading spinner đồng bộ màu Blue */
    .spinner-tech {
        color: #2563eb;
        width: 3rem;
        height: 3rem;
    }
</style>

<div class="container py-4">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/" class="text-decoration-none text-muted">Trang chủ</a></li>
            <li class="breadcrumb-item active fw-bold text-primary" aria-current="page">Cửa hàng</li>
        </ol>
    </nav>

    <div class="card modern-card mb-5">
        <div class="card-header tech-header d-flex align-items-center justify-content-between">
            <h5 class="mb-0 fw-bold"><i class="bi bi-sliders2-vertical me-2"></i> BỘ LỌC TÌM KIẾM</h5>
            <span class="badge bg-white bg-opacity-25 rounded-pill px-3">Huy Shop 2026</span>
        </div>
        <div class="card-body p-4 p-lg-5">
            <form id="formSearch" action="@Url.Action("SearchProduct", "Product")" method="get" data-target="searchResult">
                <input type="hidden" name="PageSize" value="@Model.SearchInput.PageSize" />
                <input type="hidden" name="SortOrder" id="hiddenSortOrder" value="@Model.SearchInput.SortOrder" />

                <div class="row g-4">
                    <div class="col-lg-3 col-md-6">
                        <label class="filter-label"><i class="bi bi-grid-fill me-1"></i> Danh mục</label>
                        <select name="CategoryID" class="form-select shadow-sm" onchange="paginationSearch(null, this.form, 1)">
                            <option value="0">Tất cả sản phẩm</option>
                            @foreach (var cat in Model.Categories)
                            {
                                <option value="@cat.CategoryID" selected="@(Model.SearchInput.CategoryID == cat.CategoryID)">
                                    @cat.CategoryName
                                </option>
                            }
                        </select>
                    </div>

                    <div class="col-lg-4 col-md-6">
                        <label class="filter-label"><i class="bi bi-cash-stack me-1"></i> Khoảng giá (VNĐ)</label>
                        <div class="d-flex align-items-center gap-2">
                            <input type="number" name="MinPrice" class="form-control shadow-sm" placeholder="Từ..." value="@Model.SearchInput.MinPrice" />
                            <span class="text-muted">—</span>
                            <input type="number" name="MaxPrice" class="form-control shadow-sm" placeholder="Đến..." value="@Model.SearchInput.MaxPrice" />
                        </div>
                    </div>

                    <div class="col-lg-3 col-md-8">
                        <label class="filter-label"><i class="bi bi-search me-1"></i> Tìm tên sản phẩm</label>
                        <div class="input-group shadow-sm rounded-3 overflow-hidden">
                            <input type="text" name="SearchValue" class="form-control border-end-0"
                                   value="@Model.SearchInput.SearchValue" placeholder="Bạn tìm gì hôm nay?" />
                        </div>
                    </div>

                    <div class="col-lg-2 col-md-4">
                        <label class="filter-label d-none d-lg-block">&nbsp;</label>
                        <button type="submit" class="btn btn-search-tech w-100 py-2 shadow-sm" style="height: 46px;">
                            LỌC NGAY
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div id="searchResult" class="animate__animated animate__fadeIn">
        <div class="text-center py-5">
            <div class="spinner-border spinner-tech" role="status"></div>
            <p class="mt-3 text-muted fw-medium">Đang tối ưu hóa kết quả sản phẩm...</p>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function paginationSearch(e, form, page) {
            if (e) e.preventDefault();

            var actualForm = form || document.getElementById("formSearch");
            var url = $(actualForm).attr('action');
            var targetDiv = $('#' + ($(actualForm).data('target') || 'searchResult'));

            var searchData = $(actualForm).serializeArray();
            searchData.push({ name: "Page", value: page });

            // Hiệu ứng loading chuyên nghiệp
            targetDiv.css({ 'opacity': '0.5', 'pointer-events': 'none' });

            $.ajax({
                url: url,
                type: 'GET',
                data: searchData,
                success: function (result) {
                    targetDiv.css({ 'opacity': '1', 'pointer-events': 'auto' });
                    targetDiv.html(result);

                    // Cuộn nhẹ lên đầu danh sách khi chuyển trang
                    if(page > 1 || e) {
                        $('html, body').animate({ scrollTop: targetDiv.offset().top - 100 }, 200);
                    }
                },
                error: function () {
                    targetDiv.css({ 'opacity': '1', 'pointer-events': 'auto' });
                    targetDiv.html('<div class="alert alert-danger rounded-4 shadow-sm"><i class="bi bi-exclamation-triangle me-2"></i> Lỗi kết nối máy chủ. Vui lòng thử lại!</div>');
                }
            });
        }

        $(document).ready(function () {
            var searchForm = $("#formSearch");

            // Khởi tạo tìm kiếm lần đầu
            paginationSearch(null, searchForm[0], @Model.SearchInput.Page);

            // Xử lý sự kiện Submit
            searchForm.on('submit', function (e) {
                paginationSearch(e, this, 1);
            });

            // Đồng bộ AddToCart với SweetAlert2 giống trang chủ
            $(document).on('click', '.add-to-cart', function(e) {
                e.preventDefault();
                e.stopPropagation();

                var btn = $(this);
                var productId = btn.data('product-id');

                $.post('@Url.Action("AddToCart", "Cart")', { productId: productId, quantity: 1 })
                    .done(function(res) {
                        if (res.success) {
                            Swal.fire({
                                icon: 'success',
                                title: 'Thành công!',
                                text: 'Đã thêm vào giỏ hàng',
                                timer: 1500,
                                showConfirmButton: false,
                                toast: true,
                                position: 'top-end'
                            });
                            if(typeof updateCartCount === "function") updateCartCount();
                            else if($('#cartCount').length) $('#cartCount').text(res.cartCount);
                        }
                    });
            });
        });
    </script>
}