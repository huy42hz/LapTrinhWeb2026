
@model PagedResult<Product>
@{
    Layout = null;
}

<style>
    /* Thanh công cụ phía trên */
    .search-toolbar {
        background: white;
        padding: 1rem 1.5rem;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(30, 58, 138, 0.05);
        border: 1px solid #f1f5f9;
    }

    .badge-count {
        background: rgba(37, 99, 235, 0.1);
        color: #2563eb;
        font-weight: 700;
        padding: 0.5rem 1rem;
    }

    /* Card Sản phẩm */
    .product-card {
        border: 1px solid #f1f5f9;
        border-radius: 24px;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        overflow: hidden;
    }

        .product-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 40px rgba(30, 58, 138, 0.12);
            border-color: rgba(124, 58, 237, 0.2);
        }

    .img-wrapper {
        position: relative;
        overflow: hidden;
        background: #f8fafc;
    }

        .img-wrapper img {
            transition: transform 0.6s ease;
        }

    .product-card:hover .img-wrapper img {
        transform: scale(1.1);
    }

    .card-title-tech {
        color: #1e293b;
        font-weight: 700;
        letter-spacing: -0.3px;
        transition: color 0.3s;
    }

    .product-card:hover .card-title-tech {
        color: #7c3aed;
    }

    .price-tag {
        font-weight: 800;
        font-size: 1.25rem;
        background: linear-gradient(135deg, #1e3a8a 0%, #7c3aed 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    /* Nút Mua hàng nhanh */
    .btn-buy-tech {
        background: #f1f5f9;
        color: #475569;
        border: none;
        border-radius: 12px;
        font-weight: 600;
        padding: 8px 16px;
        transition: all 0.3s;
        position: relative;
        z-index: 5;
    }

        .btn-buy-tech:hover {
            background: #7c3aed;
            color: white;
            transform: scale(1.05);
        }

    /* Phân trang */
    .pagination .page-link {
        border: none;
        border-radius: 12px !important;
        margin: 0 4px;
        color: #475569;
        font-weight: 600;
        transition: all 0.3s;
    }

    .pagination .page-item.active .page-link {
        background: linear-gradient(135deg, #1e3a8a 0%, #7c3aed 100%);
        box-shadow: 0 5px 15px rgba(124, 58, 237, 0.3);
    }
</style>

<div class="search-toolbar d-flex flex-wrap justify-content-between align-items-center mb-4">
    <div class="d-flex align-items-center">
        <div class="icon-box me-3 text-primary">
            <i class="bi bi-grid-fill fs-4"></i>
        </div>
        <h5 class="mb-0 fw-bold text-dark">
            Kết quả tìm kiếm <span class="badge rounded-pill badge-count ms-2">@Model.RowCount</span>
        </h5>
    </div>

    <div class="dropdown">
        <button class="btn btn-light rounded-pill dropdown-toggle fw-bold px-4 border" type="button" data-bs-toggle="dropdown">
            <i class="bi bi-sliders me-2"></i> Sắp xếp
        </button>
        <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 rounded-4 p-2 mt-2">
            <li><a class="dropdown-item rounded-3 py-2" href="javascript:;" onclick="setSort('newest')">Mới nhất</a></li>
            <li><a class="dropdown-item rounded-3 py-2" href="javascript:;" onclick="setSort('price_asc')">Giá thấp đến cao</a></li>
            <li><a class="dropdown-item rounded-3 py-2" href="javascript:;" onclick="setSort('price_desc')">Giá cao đến thấp</a></li>
        </ul>
    </div>
</div>

<div class="row g-4">
    @foreach (var product in Model.DataItems)
    {
        <div class="col-lg-4 col-md-6">
            <div class="card h-100 bg-white product-card">
                <div class="img-wrapper">
                    <img src="~/images/products/@(string.IsNullOrEmpty(product.Photo) ? "nophoto.png" : product.Photo)"
                         class="card-img-top" alt="@product.ProductName" style="height: 240px; object-fit: contain; padding: 20px;">
                </div>

                <div class="card-body d-flex flex-column p-4">
                    <h6 class="card-title-tech mb-2 text-truncate" title="@product.ProductName">
                        @product.ProductName
                    </h6>

                    <p class="text-muted small mb-4 flex-grow-1" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                        @product.ProductDescription
                    </p>

                    <div class="d-flex justify-content-between align-items-center pt-3 border-top border-light">
                        <div class="price-tag">@product.Price.ToString("#,##0") đ</div>
                        <button class="btn-buy-tech add-to-cart-simple" data-id="@product.ProductID">
                            <i class="bi bi-plus-lg"></i> Mua
                        </button>
                    </div>
                </div>

                <a href="@Url.Action("Detail", "Product", new { id = product.ProductID })" class="stretched-link"></a>
            </div>
        </div>
    }
</div>

@if (Model.DataItems.Count == 0)
{
    <div class="text-center py-5 my-4 bg-light rounded-5 border border-dashed">
        <div class="mb-3">
            <i class="bi bi-search-heart display-1 text-muted opacity-25"></i>
        </div>
        <h4 class="fw-bold text-dark">Rất tiếc, không tìm thấy kết quả</h4>
        <p class="text-muted">Hãy thử thay đổi từ khóa hoặc sử dụng các bộ lọc khác nhé!</p>
    </div>
}

@if (Model.PageCount > 1)
{
    <nav class="mt-5 mb-2">
        <ul class="pagination justify-content-center">
            @foreach (var p in Model.GetDisplayPages())
            {
                if (p.IsCurrent)
                {
                    <li class="page-item active"><a class="page-link shadow-sm" href="javascript:;">@p.Page</a></li>
                }
                else if (p.IsEllipsis)
                {
                    <li class="page-item disabled"><a class="page-link" href="javascript:;">...</a></li>
                }
                else
                {
                    <li class="page-item">
                        <a class="page-link shadow-sm bg-white border"
                           href="javascript:;"
                           onclick="paginationSearch(event, document.getElementById('formSearch'), @p.Page)">
                            @p.Page
                        </a>
                    </li>
                }
            }
        </ul>
    </nav>
}

<script>
    // Hàm hỗ trợ cập nhật hidden field và gọi search
    function setSort(order) {
        var sortInput = document.getElementById('hiddenSortOrder');
        if(sortInput) {
            sortInput.value = order;
            paginationSearch(null, document.getElementById('formSearch'), 1);
        }
    }
</script>