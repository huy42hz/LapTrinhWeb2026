@using System.Security.Claims
@{
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    var displayName = isAuthenticated ? (User.FindFirst("DisplayName")?.Value ?? User.FindFirst(ClaimTypes.Name)?.Value ?? "User") : "";
    var firstChar = !string.IsNullOrEmpty(displayName) ? displayName.Substring(0, 1).ToUpper() : "U";
}

<nav class="navbar navbar-expand-lg fixed-top bg-white border-bottom py-2 shadow-sm main-navbar">
    <div class="container-fluid px-4">
        <a href="~/" class="navbar-brand shop-logo-tech me-4">
            <span class="logo-blue">Huy</span><span class="logo-purple">Shop</span>
        </a>

        <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#navContent">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navContent">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0 gap-1">
                <li class="nav-item">
                    <a href="~/" class="nav-link tech-nav-link px-3">Trang chủ</a>
                </li>
                <li class="nav-item">
                    <a href="~/Product" class="nav-link tech-nav-link px-3">Sản phẩm</a>
                </li>
            </ul>

            <div class="d-flex align-items-center gap-3">
                <a href="~/Cart" class="btn btn-cart-tech position-relative rounded-pill px-3 py-2">
                    <i class="fa-solid fa-cart-shopping me-2"></i>
                    <span class="fw-bold small">GIỎ HÀNG</span>
                    <span id="cartCount" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-purple-gradient shadow-sm">0</span>
                </a>

                @if (isAuthenticated)
                {
                    <div class="dropdown">
                        <div class="user-profile-pill d-flex align-items-center gap-2 border rounded-pill p-1 pe-3" data-bs-toggle="dropdown">
                            <div class="avatar-tech text-white rounded-circle d-flex align-items-center justify-content-center fw-bold shadow-sm">
                                @firstChar
                            </div>
                            <span class="fw-bold small d-none d-md-block text-dark">@displayName</span>
                        </div>
                        <ul class="dropdown-menu dropdown-menu-end border-0 shadow-lg mt-3 p-2 rounded-4 animate__animated animate__fadeInUp">
                            <li><h6 class="dropdown-header small text-uppercase fw-black opacity-50">Tài khoản</h6></li>
                            <li><a class="dropdown-item rounded-3 py-2" href="~/ShopAccount/Profile"><i class="fa-regular fa-user me-2 text-primary"></i>Hồ sơ cá nhân</a></li>
                            <li><a class="dropdown-item rounded-3 py-2" href="~/Order"><i class="fa-solid fa-receipt me-2 text-success"></i>Đơn hàng của tôi</a></li>
                            <li><a class="dropdown-item rounded-3 py-2" href="~/ShopAccount/ChangePassword"><i class="fa-solid fa-key me-2 text-warning"></i>Đổi mật khẩu</a></li>
                            <li><hr class="dropdown-divider opacity-50"></li>
                            <li><a class="dropdown-item rounded-3 py-2 text-danger fw-bold" href="~/ShopAccount/Logout"><i class="fa-solid fa-power-off me-2"></i>Đăng xuất</a></li>
                        </ul>
                    </div>
                }
                else
                {
                    <div class="d-flex gap-2 align-items-center">
                        <a href="~/ShopAccount/Login" class="btn-login-link fw-bold small text-decoration-none px-3">ĐĂNG NHẬP</a>
                        <a href="~/ShopAccount/Register" class="btn btn-register-pill rounded-pill px-4 shadow-sm fw-bold small">ĐĂNG KÝ</a>
                    </div>
                }
            </div>
        </div>
    </div>
</nav>

<style>
    /* Tổng thể Navbar */
    .main-navbar {
        backdrop-filter: blur(10px);
        background: rgba(255, 255, 255, 0.9) !important;
    }

    /* Logo Styling (Đồng bộ với trang Login) */
    .shop-logo-tech {
        font-size: 1.8rem;
        font-weight: 900;
        letter-spacing: -1px;
        text-decoration: none;
    }

    .logo-blue {
        color: #1e3a8a;
    }

    .logo-purple {
        background: linear-gradient(135deg, #1e3a8a 0%, #7c3aed 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    /* Link Menu Style */
    .tech-nav-link {
        font-weight: 700;
        color: #475569 !important;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        position: relative;
        transition: all 0.3s;
    }

        .tech-nav-link:hover {
            color: #7c3aed !important;
        }

        .tech-nav-link::after {
            content: "";
            position: absolute;
            bottom: 5px;
            left: 15px;
            right: 15px;
            height: 2px;
            background: #7c3aed;
            transform: scaleX(0);
            transition: transform 0.3s;
        }

        .tech-nav-link:hover::after {
            transform: scaleX(1);
        }

    /* Cart Button Tech Style */
    .btn-cart-tech {
        background: #f1f5f9;
        color: #1e3a8a;
        border: 1px solid #e2e8f0;
        transition: all 0.3s;
    }

        .btn-cart-tech:hover {
            background: white;
            border-color: #7c3aed;
            color: #7c3aed;
            transform: translateY(-2px);
        }

    .bg-purple-gradient {
        background: linear-gradient(135deg, #ef4444 0%, #7c3aed 100%);
    }

    /* User Profile Pill */
    .user-profile-pill {
        background: #f8fafc;
        cursor: pointer;
        transition: all 0.3s;
    }

        .user-profile-pill:hover {
            background: white;
            border-color: #7c3aed !important;
            box-shadow: 0 5px 15px rgba(124, 58, 237, 0.1);
        }

    .avatar-tech {
        background: linear-gradient(135deg, #1e3a8a 0%, #7c3aed 100%);
        width: 32px;
        height: 32px;
        font-size: 0.8rem;
    }

    /* Buttons Auth */
    .btn-login-link {
        color: #475569;
        transition: color 0.3s;
    }

        .btn-login-link:hover {
            color: #1e3a8a;
        }

    .btn-register-pill {
        background: linear-gradient(135deg, #1e3a8a 0%, #7c3aed 100%);
        color: white;
        border: none;
        transition: all 0.3s;
    }

        .btn-register-pill:hover {
            filter: brightness(1.1);
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(124, 58, 237, 0.3) !important;
            color: white;
        }

    /* Dropdown Animation */
    .dropdown-menu {
        min-width: 220px;
        transform-origin: top right;
    }

    .dropdown-item {
        font-weight: 600;
        font-size: 0.9rem;
        color: #475569;
        transition: all 0.2s;
    }

        .dropdown-item:hover {
            background-color: #f1f5f9;
            color: #7c3aed;
            padding-left: 1.5rem;
        }
</style>